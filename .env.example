# Google Maps API / Forge Settings
VITE_FRONTEND_FORGE_API_KEY=your_google_maps_api_key_here
VITE_FRONTEND_FORGE_API_URL=https://api.yourdomain.com

# Analytics Settings (Optional)
VITE_ANALYTICS_ENDPOINT=https://your-analytics-domain.com
VITE_ANALYTICS_WEBSITE_ID=your-website-uuid-here

# OAuth Settings (Optional, unused in active code)
VITE_OAUTH_PORTAL_URL=https://oauth.yourdomain.com
VITE_APP_ID=your-app-id-here
